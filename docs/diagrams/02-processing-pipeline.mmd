flowchart TD
    Start([🚀 Start Processing]) --> Input

    subgraph Input["📥 Data Ingestion"]
        RINEX["📄 RINEX Files\n(.XXo, all constellations)"]
        SBF["📡 SBF Files\n(.XX_, Septentrio)"]
        SP3["🛰️ SP3 Files\n(Precise Orbits)"]
        CLK["⏰ CLK Files\n(Precise Clocks)"]
    end

    subgraph Reading["🔍 Reading & Parsing"]
        RinexReader["Rnxv3Obs\nParse RINEX v3.04"]
        SbfReader["SbfReader\nSingle-pass binary decode"]
        AuxReader["SP3/CLK Parsers\nLoad Auxiliary Data"]
    end

    subgraph Processing["⚙️ Processing — RINEX path"]
        Interp["Hermite Interpolation\nOrbits/clocks → obs epochs"]
        Position["Coordinate Transform\nECEF → spherical (r, θ, φ)"]
        Augment["Dataset Augmentation\nMerge RINEX + geometry"]
    end

    subgraph SBFPath["⚡ Processing — SBF path (no download)"]
        SbfObs["Observations Dataset\nSNR · PR · Phase · Doppler\n(epoch × sid)"]
        SbfMeta["Metadata Dataset\nDOP · PVT · θ · φ · quality\n(epoch, epoch × sid)"]
    end

    subgraph Storage["💾 Versioned Storage (Icechunk)"]
        Icechunk["Observations Store\n(epoch × sid)"]
        MetaStore["Metadata Store\ngroup/metadata/sbf_obs"]
    end

    subgraph Analysis["📊 Analysis"]
        GridAssign["Hemispheric Grid Assignment\nEqual-area / HEALPix / geodesic"]
        VODCalc["VOD Retrieval\nTau-Omega model · canopy vs reference"]
        Aggregate["Aggregation\nPer-cell statistics"]
    end

    subgraph Output["📈 Output"]
        Viz2D["2D Hemisphere Plots\nPolar projection"]
        Viz3D["3D Interactive Plots\nPlotly surface"]
        Export["Data Export\nNetCDF / CSV"]
    end

    RINEX --> RinexReader
    SP3 --> AuxReader
    CLK --> AuxReader

    RinexReader --> Augment
    AuxReader --> Interp
    Interp --> Position
    Position --> Augment
    Augment --> Icechunk

    SBF --> SbfReader
    SbfReader --> SbfObs
    SbfReader --> SbfMeta
    SbfObs --> Icechunk
    SbfMeta --> MetaStore

    Icechunk --> GridAssign
    GridAssign --> VODCalc
    VODCalc --> Aggregate

    Aggregate --> Viz2D
    Aggregate --> Viz3D
    Aggregate --> Export

    Viz2D --> End([✅ Complete])
    Viz3D --> End
    Export --> End

