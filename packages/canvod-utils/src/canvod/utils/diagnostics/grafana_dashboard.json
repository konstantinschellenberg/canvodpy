{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Pipeline overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "Task success rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(canvod_*_success_total[$__range])) / (sum(increase(canvod_*_success_total[$__range])) + sum(increase(canvod_*_failed_total[$__range]))) * 100",
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "#C75050", "value": null },
              { "color": "#D4A843", "value": 90 },
              { "color": "#5D7D5B", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Tasks completed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(canvod_*_success_total[$__range]))",
          "legendFormat": "Completed"
        }
      ]
    },
    {
      "title": "Tasks failed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(canvod_*_failed_total[$__range]))",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "#5D7D5B", "value": null },
              { "color": "#D4A843", "value": 1 },
              { "color": "#C75050", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Peak memory (max)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "max(canvod_*_peak_memory_mb)",
          "legendFormat": "Peak MB"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "title": "Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "title": "Task duration over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "canvod_ingest_rinex_duration_s",
          "legendFormat": "ingest_rinex"
        },
        {
          "expr": "canvod_store_write_duration_s",
          "legendFormat": "store_write"
        },
        {
          "expr": "canvod_aux_preprocess_duration_s",
          "legendFormat": "aux_preprocess"
        },
        {
          "expr": "canvod_vod_compute_duration_s",
          "legendFormat": "vod_compute"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Memory usage over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "canvod_*_peak_memory_mb",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "drawStyle": "bars", "fillOpacity": 40 }
        }
      }
    },
    {
      "title": "Duration distribution (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(canvod_ingest_rinex_duration_s_bucket[$__rate_interval]))",
          "legendFormat": "ingest_rinex p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(canvod_ingest_rinex_duration_s_bucket[$__rate_interval]))",
          "legendFormat": "ingest_rinex p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(canvod_store_write_duration_s_bucket[$__rate_interval]))",
          "legendFormat": "store_write p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(canvod_store_write_duration_s_bucket[$__rate_interval]))",
          "legendFormat": "store_write p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "title": "Task outcomes (success vs failed)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "sum(increase(canvod_*_success_total[$__range]))",
          "legendFormat": "Success"
        },
        {
          "expr": "sum(increase(canvod_*_failed_total[$__range]))",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": "#5D7D5B" }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": "#C75050" }] }
        ]
      }
    },
    {
      "title": "Throughput (tasks/hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 23 },
      "targets": [
        {
          "expr": "sum(rate(canvod_*_success_total[1h])) * 3600",
          "legendFormat": "tasks/hour"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "color": { "fixedColor": "#5D7D5B", "mode": "fixed" }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["canvod", "gnss", "pipeline"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "canvod pipeline health",
  "uid": "canvod-pipeline-health"
}
