# =============================================================================
# Processing Configuration Template
# =============================================================================
# Copy this file to config/processing.yaml and customize for your setup
# Run: just config-init

# =============================================================================
# Metadata (Written to Processed Files)
# =============================================================================

metadata:
  author: Your Name
  email: your.email@example.com
  institution: Your Institution
  department: Your Department  # Optional
  research_group: Your Research Group  # Optional
  website: https://your-institution.edu  # Optional

# =============================================================================
# Credentials
# =============================================================================

credentials:
  # NASA Earthdata email for CDDIS FTP authentication (optional)
  # Register at: https://urs.earthdata.nasa.gov/users/new
  # If set: NASA CDDIS primary, ESA fallback
  # If not set: ESA only (no auth required)
  nasa_earthdata_acc_mail: null

# =============================================================================
# Auxiliary Data
# =============================================================================

aux_data:
  agency: COD              # Analysis center: COD, GFZ, IGS, ESA, etc.
  product_type: final      # final, rapid, ultra-rapid

  # FTP server selection:
  # - If nasa_earthdata_acc_mail is set: NASA primary, ESA fallback
  # - If nasa_earthdata_acc_mail is null: ESA only (no auth required)
  #
  # ESA server: ftp://gssc.esa.int/gnss (no auth, always available)
  # NASA server: ftp://gdc.cddis.eosdis.nasa.gov (requires Earthdata account)

# =============================================================================
# Processing Parameters
# =============================================================================

processing:

  # --- RINEX observation settings -----------------------------------------
  # Variables to keep. Each maps to a RINEX obs code prefix:
  #   SNR         - Signal-to-Noise Ratio (dBHz)   [S-codes: S1C, S2W, ...]
  #   Pseudorange - Code pseudorange (metres)       [C-codes: C1C, C2W, ...]
  #   Phase       - Carrier phase (cycles)          [L-codes: L1C, L2W, ...]
  #   Doppler     - Doppler shift (Hz)              [D-codes: D1C, D2W, ...]
  keep_rnx_vars:
    - SNR
    # - Pseudorange
    # - Phase
    # - Doppler
  aggregate_glonass_fdma: true    # If true, GLONASS FDMA signals are aggregated into effective bands G1* and G2*, with center frequencies being the mean of the respective FDMA sub-bands and bandwidth stretching across all sub-bands incl. their respective bandwidhts
  store_radial_distance: false   # If true, store satellite-receiver distance (r) alongside phi/theta
  receiver_position_mode: shared  # 'shared': all receivers use canopy position (default, enables 1:1 SNR comparison). 'per_receiver': each receiver uses its own RINEX header position (⚠ breaks direct SNR comparability between receivers).

  # --- Batch strategy -----------------------------------------------------
  # >= 24: multi-day strategy (accumulates calendar days)
  # <  24: sub-day strategy (splits RINEX files within a day)
  batch_hours: 24

  # --- Resource mode ------------------------------------------------------
  # 'auto'   — Dask/OS auto-detects workers and memory (personal machines)
  # 'manual' — hard caps below are enforced (shared servers)
  resource_mode: auto

  # --- Parallelism primer ------------------------------------------------
  # Your CPU has a fixed number of "cores" — independent units that can
  # each run one computation at the same time. Check yours with:
  #   python -c "import os; print(os.cpu_count())"
  #
  # A "worker" is a separate Python process that occupies one core.
  # Setting n_max_threads higher than your core count gives no speed-up
  # for CPU-heavy work (like RINEX processing) and can actually slow
  # things down because workers compete for the same cores.
  #
  # A "thread" is a lightweight path inside a single worker. Threads
  # help with waiting on disk or network I/O, but Python's GIL (Global
  # Interpreter Lock) prevents them from speeding up number crunching.
  # canvodpy uses 1 thread per worker, so each worker = 1 process = 1 core.
  #
  # Rule of thumb: set n_max_threads equal to your core count (or a bit
  # below to leave headroom for the OS). On a laptop with 8 cores, 6-8
  # is a good starting point.
  # -----------------------------------------------------------------------

  # Manual-mode settings (ignored when resource_mode: auto)
  # n_max_threads: 8           # Worker processes (≤ your core count)
  # max_memory_gb: 16          # Total RAM budget (null = no limit)
  # cpu_affinity: [0, 1, 2, 3] # Pin to CPU core IDs, Linux only
  # nice_priority: 10          # OS priority (0 = normal, 19 = lowest)
  # threads_per_worker: 1      # Threads per worker (1 for 24h files, 2-4 for 15-min files)

  # Dask dashboard: http://localhost:8787/status

# =============================================================================
# Preprocessing Pipeline
# =============================================================================
# Operations applied automatically during ingestion (after augmentation).
# Each step can be disabled or tuned independently.

preprocessing:
  temporal_aggregation:
    enabled: true
    freq: "1min"           # pandas offset alias: "1min", "30s", "5min", etc.
    method: "mean"         # "mean" or "median"

  grid_assignment:
    enabled: true
    grid_type: "equal_area"
    angular_resolution: 2.0  # degrees (0 < value ≤ 90)

# =============================================================================
# Compression
# =============================================================================

compression:
  zlib: true
  complevel: 5

# =============================================================================
# Icechunk Storage
# =============================================================================

icechunk:
  compression_level: 5
  compression_algorithm: zstd  # zstd, lz4, gzip
  inline_threshold: 512        # Bytes; chunks ≤ this are inlined into the manifest
  get_concurrency: 1           # Concurrent partial-value reads (increase for S3/GCS)

  # Manifest preloading — loads coordinate manifests into memory at session open.
  # Worth enabling once stores grow beyond a few hundred commits.
  # manifest_preload_enabled: false
  # manifest_preload_max_refs: 100000000   # Cap on chunk refs preloaded
  # manifest_preload_pattern: "epoch|sid"  # Regex for arrays to preload

  chunk_strategies:
    rinex_store:
      epoch: 34560  # 2 days of 5s data
      sid: -1       # Don't chunk along sid
    vod_store:
      epoch: 34560
      sid: -1

# =============================================================================
# Storage Strategies
# =============================================================================

storage:
  # Root directory for all IceChunk stores
  # Stores will be organized as: {stores_root_dir}/{site_name}/{rinex_store_name}/
  #                              {stores_root_dir}/{site_name}/{vod_store_name}/
  stores_root_dir: /path/to/your/gnss/stores

  # Custom store directory names (default: "rinex" and "vod")
  # rinex_store_name: rinex
  # vod_store_name: vod

  # Directory for downloaded auxiliary files (SP3, CLK) and transient Zarr caches.
  # Raw SP3/CLK files are kept across runs; Zarr caches are rebuilt each time.
  # If not set, uses system temp directory.
  # aux_data_dir: /path/to/aux_data

  rinex_store_strategy: skip      # skip, overwrite, append
  rinex_store_expire_days: 2
  vod_store_strategy: overwrite

# =============================================================================
# Logging
# =============================================================================

logging:
  # Directory for log files. If not set, defaults to .logs/ in monorepo root
  # log_dir: /path/to/logs
  log_file_name: canvodpy.log
  log_path_depth: 6              # Path components shown in log references
