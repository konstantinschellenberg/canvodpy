# =============================================================================
# Research Sites Configuration Template
# =============================================================================
# Copy this file to config/sites.yaml and customize for your setup.
# Run: just config-init
#
# Each receiver needs a "recipe" — a small YAML file that describes how to
# extract date/time fields from your filenames. Recipes live in
# config/recipes/{recipe_name}.yaml. See config/recipes/ for examples.

sites:
  # Example site configuration
  rosalia:
    # Absolute path to site data directory
    gnss_site_data_root: /path/to/your/gnss/data/01_Rosalia

    # Site geospatial metadata (optional, used by canvod-store-metadata)
    description: Mixed forest GNSS-T research site
    country: AT                # ISO 3166-1 alpha-2 country code
    latitude: 47.7             # WGS84 latitude (decimal degrees)
    longitude: 16.3            # WGS84 longitude (decimal degrees)
    altitude_m: 680.0          # Altitude above WGS84 ellipsoid (metres)

    # Optional site-level naming convention override
    # naming:
    #   convention: "{SIT}{T}{NN}{AGC}_R_{YYYY}{DOY}{HHMM}_{PERIOD}_{SAMPLING}_{CONTENT}.{TYPE}"

    # Receiver definitions
    receivers:
      reference_01:
        type: reference
        directory: 01_reference             # subdirectory under gnss_site_data_root
        reader_format: auto                 # 'auto', 'rinex3', or 'sbf'
        scs_from: all                       # 'all' or list of canopy receiver names
        description: First reference receiver (open sky)
        recipe: rosalia_reference           # → config/recipes/rosalia_reference.yaml

        # Optional freeform metadata written to dataset global attrs
        metadata:
          site_url: https://forschung.boku.ac.at/rosalia
          antenna_height: 2.0

      canopy_01:
        type: canopy
        directory: 02_canopy
        reader_format: auto
        description: First canopy receiver (under vegetation)
        recipe: rosalia_canopy              # → config/recipes/rosalia_canopy.yaml

        metadata:
          site_url: https://forschung.boku.ac.at/rosalia
          antenna_height: 1.5
          species: Fagus sylvatica

      # canopy_02:
      #   type: canopy
      #   directory: 03_canopy_ext1
      #   description: Second canopy receiver
      #   recipe: rosalia_canopy_02         # → config/recipes/rosalia_canopy_02.yaml
      #   metadata:
      #     species: Picea abies

    # VOD analysis pairs
    vod_analyses:
      canopy_01_vs_reference_01:
        canopy_receiver: canopy_01
        reference_receiver: reference_01
        description: VOD analysis canopy_01 vs reference_01

      # canopy_02_vs_reference_01:
      #   canopy_receiver: canopy_02
      #   reference_receiver: reference_01
      #   description: VOD analysis canopy_02 vs reference_01

  # Add more sites as needed
  # tuw:
  #   gnss_site_data_root: /path/to/your/gnss/data/02_TUW
  #   receivers:
  #     reference_01:
  #       type: reference
  #       directory: 01_reference
  #       scs_from: all
  #       recipe: tuw_reference
  #     canopy_01:
  #       type: canopy
  #       directory: 02_canopy
  #       recipe: tuw_canopy
  #   vod_analyses:
  #     canopy_01_vs_reference_01:
  #       canopy_receiver: canopy_01
  #       reference_receiver: reference_01
