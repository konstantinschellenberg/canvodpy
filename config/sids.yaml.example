# =============================================================================
# Signal IDs (SIDs) Configuration Template
# =============================================================================
# Copy this file to config/sids.yaml and customize for your setup.
# Run: just config-init
#
# SID Format: PRN|Band|Code
#   PRN  — Constellation prefix + 2-digit satellite number
#           G = GPS, E = Galileo, R = GLONASS, C = BeiDou,
#           I = IRNSS/NavIC, S = SBAS, J = QZSS
#   Band — Frequency band (L1, L2, E1, E5a, E5b, B1I, B2b, B3I, G1, G2, L5)
#   Code — RINEX tracking mode (C = C/A, W = P(Y) codeless, L = L2C,
#           Q = pilot, I = I-channel, A = A-channel)
#
# Example: G01|L1|C = GPS PRN01, L1 band, C/A code
#          E02|E5a|Q = Galileo E02, E5a band, Q (pilot) tracking

# =============================================================================
# SID Selection Mode
# =============================================================================
# Modes:
#   all    — Keep every SID found in the RINEX/SBF file (no filtering)
#   preset — Use a named preset (gps_galileo, multi_gnss, gps_only)
#   custom — Keep only the SIDs explicitly listed in custom_sids below

mode: all

# =============================================================================
# Preset Mode (when mode: preset)
# =============================================================================
# Available presets:
#   - gps_galileo: GPS + Galileo signals only
#   - multi_gnss: GPS + Galileo + GLONASS + BeiDou
#   - gps_only: GPS signals only

# preset: gps_galileo

# =============================================================================
# Custom Mode (when mode: custom)
# =============================================================================
# Specify exact SIDs to keep

# custom_sids:
#   # GPS L1
#   - G01|L1|C
#   - G02|L1|C
#   - G03|L1|C
#
#   # GPS L2
#   - G01|L2|W
#   - G02|L2|W
#   - G03|L2|W
#
#   # Galileo E1
#   - E01|E1|C
#   - E02|E1|C
#
#   # Add more SIDs as needed...
